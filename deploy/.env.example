# Пример переменных окружения для тренажёра мнемотехники
# Скопируйте в .env и заполните своими значениями: cp deploy/.env.example .env

# Строка подключения к базе PostgreSQL
# Формат: postgresql://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БАЗЫ
DATABASE_URL=postgresql://mnemonics:ПАРОЛЬ@localhost:5432/mnemonics

# Случайная длинная строка (можно сгенерировать: openssl rand -hex 32)
SESSION_SECRET=замените_на_случайную_строку

# Порт API-сервера (должен совпадать с nginx и pm2)
PORT=8080

# Режим работы
NODE_ENV=production

# Базовый путь фронтенда (нужен на этапе сборки)
BASE_PATH=/
